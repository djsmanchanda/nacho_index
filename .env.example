# Cloudflare (for remote D1 migrations via drizzle-kit)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id
CLOUDFLARE_API_TOKEN=your_api_token

# Password required before /add allows review entry
NACHO_ADD_REVIEW_PASSWORD=change-me

# Optional: override wrangler database id after `wrangler d1 create nacho-index-db`
# Update wrangler.jsonc d1_databases[0].database_id with the real ID
